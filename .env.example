# Copy to .env and fill in real values. Never commit .env.
# Rotate any key that has appeared in chat, screenshots, or commits.

TAVILY_API_KEY=your_tavily_key_here
GEMINI_API_KEY=your_google_ai_studio_key_here
GEMINI_MODEL=gemma-3-27b-it

# Optional — enables Finnhub as the primary quote/profile/metrics/news source.
# Free tier: https://finnhub.io/register (60 calls/min)
# If unset, Stooq is used for historical OHLCV and Yahoo is used as fallback
# for quote/stats (subject to Yahoo's IP rate limits).
FINNHUB_API_KEY=your_finnhub_key_here

PORT=3001
CACHE_DB_PATH=./cache.sqlite
